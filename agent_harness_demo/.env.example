# 复制为 .env 后填写。OpenAI-compatible 本地/远程模型配置。
# 例如本地用 vLLM / Ollama / LM Studio 时，把 OPENAI_BASE_URL 指向本地服务。

# 是否启用真实模型客户端；为空或 false 时使用 MockModelClient
USE_REAL_MODEL=false

# OpenAI-compatible API 配置
OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_API_KEY=EMPTY
OPENAI_MODEL=default-model

# Agent 主循环最大轮数
AGENT_MAX_STEPS=5

# Trace 输出文件路径（相对项目根目录）
TRACE_FILE=traces.jsonl
